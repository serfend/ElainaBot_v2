# ===== ElainaBot 环境变量配置 =====
# 复制此文件为 .env 并填入真实值
# .env 已加入 .gitignore, 不会提交到仓库
#
# 注意: 机器人 (appid / secret / robot_qq) 通过 Web 面板管理, 不在此配置
#       启动后访问 Web 面板 → 配置 → 可视化编辑 → 保存即可

# --- Web 面板认证 ---
ACCESS_TOKEN=admin
ADMIN_PASSWORD=your_admin_password_here

# --- 图床服务 (Nature / 腾讯云 COS) ---
# NATURE_SECRET_ID=your_tencent_cloud_secret_id
# NATURE_SECRET_KEY=your_tencent_cloud_secret_key
